function TForm1.GetTextCount(filename, TextToCount, EndString: string):integer;
var SL: TStringList;
    x, Count: integer;
begin
  result := 0;

  SL := TStringList.create;
  try
    SL.LoadFromFile(filename);
    For x := GetHeaderCommentSize(filename, '#') to SL.Count-1 do //First 3 lines are usually comments
      If ContainsText(SL.Strings[x], TextToCount) then
      begin
        TryStrToInt(ReturnStringBetweenText(TextToCount, EndString, SL.Strings[x]),Count);
        If Count > result then
          result := Count
      end;
  finally
    SL.Free;
  end;

end;

function TForm1.GetHeaderCommentSize(filename, CommentChar: string):integer;
var SL: TStringList;
    x: integer;
begin
  result := 0;
  SL := TStringList.create;
  try
    SL.LoadFromFile(filename);
    For x := 1 to SL.Count-1 do
      If ContainsText(SL.Strings[x], CommentChar) then inc(result) else break
  finally
    SL.Free;
  end;

end;

procedure TForm1.BuildPolyList;
var SL: TStringList;
    x,y,z, NodeCount: integer;
    exactmatch, nomatch: integer;
    Parent_id, Orthochild, RingChild: integer;
    SearchString, CurrentLine, Location, WGS, U, V, texvert{, CurrentMaterial,}: string;
