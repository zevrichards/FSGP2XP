begin

  {Order of Operations:
  Search for faces which will become rings
  Create new orthophoto for each ring
  Save group of face to match holes to orthophotos later
  Use face normals to determine whether face should be hole or outer ring
  Add ring to orthophoto children
  Collect all nodes
  Add nodes to ring children
  GO through list of orthophoto rings which are holes
  Remove them from their own orthophoto children and place them in matching orthophoto outer rings children
  Delete orthophotos/rings with 0 children and remove from WED Group children list}

  WedGroupList := TObjectList<TWED_Group>.create;

  //initialize unique next ID number from WED XML
  id_count:= GetTextCount(WEDXMLEdit.Text, ' id="', '"')+1;      //+1 to make space for new WED_Group
  existing_elements := id_count-1;
  Memo1.Lines.Add('Highest ID value in earth.wed.xml is '+IntToStr(existing_elements));

  //initialize number of holes already in WED XML
  hole_count:= GetTextCount(WEDXMLEdit.Text, 'name="Hole ', '"')+1;
  Memo1.Lines.Add('Total holes already in earth.wed.xml is '+IntToStr(hole_count-1));

  //central coordinates record
  central_coord.long := StrToFloat(LongEdit.Text);
  central_coord.lat := StrToFloat(LatEdit.Text);

  //initialize the WED Group
  aWedGroup:= TWED_Group.Create;
  aWedGroup.id := id_count;
  inc(id_count);
  aWedGroup.parent_id := 4;        //4 = world
  aWedGroup.name := 'GP Objects';
  AWedGroup.children := TList<Integer>.create;  //create empty list for children to be added later
  WedGroupList.Add(aWedGroup);
  Memo1.Lines.Add('WED Group  ID: '+IntToStr(aWedGroup.id)+'  Name: '+ aWedGroup.name+'  Parent ID: '+ IntToStr(aWedGroup.parent_id));

  //open OBJ file to begin searching for line groups which will become Wed Rings
  SL := TSTringList.Create;
  WedOrthoList := TObjectList<TWED_DrapedOrthophoto>.Create;
  WedRingList := TObjectList<TWed_Ring>.Create;
  WedNodeList := TObjectList<TWED_TextureBezierNode>.Create;
  try

    SL.LoadFromFile(OBJEdit.Text);
    z := 0;
    {CurrentMaterial := '';}


    {Search for faces which will become rings}

    //for every 'g Mesh' we find we will create a new WED Ring and add it to the list as a child of the WED Ortho
    //then we will search for every vertex and create a new WED Node and add it to the list as a child of the WED Ring
    //THIS CODE ASSUMES THAT THE OBJ FILE IS MADE FROM SKETCHUP, AND EVERY MESH REPRESENTS ONE FACE AND IS NOT TRIANGULATED.
    //FACES WHICH REPRSENT HOLES SHOULD ALSO BE IN THE SAME MESH GROUP AS THE FACE IT WILL BE A HOLE IN
    For x := GetHeaderCommentSize(OBJEdit.Text, '#') to SL.Count-1 do    //First 3 lines are usually comments
    begin

      //Search for 'g Mesh'
      If ContainsText(SL.Strings[x], 'g Mesh') then
      begin

        {Create new orthophoto for each ring}

        //initialize WED Ortho
        aWedOrtho:= TWED_DrapedOrthoPhoto.Create;
        aWedOrtho.id := id_count;
        inc(id_count);
        aWedOrtho.parent_id := aWedGroup.id;
        aWedGroup.children.Add(aWedOrtho.id); //add to child list of parent
        aWedOrtho.name := TPath.GetFileNameWithoutExtension(OBJEdit.Text)+'_'+IntToStr(id_count-1);
        aWedOrtho.heading := StrToFloat(TexRotEdit.Text);
        aWedOrtho.resource := PolPathEdit.Text +'\'+ PolEdit.Text +'.pol';
        aWedOrtho.children := TList<Integer>.create;  //create empty list for children to be added later
        //initialize texture extremties to later fit texture to the size of the ring.
        aWedOrtho.TexTop := -999999;
        aWedOrtho.TexBottom := 999999;
        aWedOrtho.TexLeft := -999999;
        aWedOrtho.TexRight := 999999;
        WedOrthoList.add(aWedOrtho);
        Memo1.Lines.Add('WED Ortho  ID: '+IntToStr(aWedOrtho.id)+'  Parent ID: '+ IntToStr(aWedOrtho.parent_id)+'  Name/Resource: '+aWedOrtho.name);

        //initiialze WED Ring
        aWedRing:= TWed_Ring.Create;
        aWedRing.id := id_count;
        inc(id_count);
        aWedRing.parent_id := aWedOrtho.id;
        {Add ring to orthophoto children}
        aWedOrtho.children.Add(aWedRing.id); //add to child list of parent

        {Save Group of face to match holes to orthophotos later}
        //Check for the group. We will use these to match holes to their parent rings
        If ContainsText(SL.Strings[x], 'Group') then
        begin
          aWEDRing.Group := ReturnStringBetweenText('Group',' Model',SL.Strings[x]);
          aWEDOrtho.Group := aWEDRing.Group;
        end
        else
        begin
          aWEDRing.Group := '';
          aWEDOrtho.Group := '';
        end;

        aWedRing.isHole := false;
        aWedRing.name := TPath.GetFileNameWithoutExtension(OBJEdit.Text)+'_Outer Ring_'+IntToStr(id_count-1);
        aWedRing.children := TList<Integer>.create;  //create empty list for children to be added later
        //add to WED Ring List
        WedRingList.Add(aWedRing);
        Memo1.Lines.Add('WED Ring  ID: '+IntToStr(aWedRing.id)+'  Parent ID: '+ IntToStr(aWedRing.parent_id)+'  Name: '+aWedRing.name);

        //Start new Node Count for this ring
        NodeCount := 1;
      end
      else
      begin
          {Use face normals to determine whether face should be hole or outer ring}

          //Check for normals 'vn'. We will use this to determine whether a ring is a hole or not. Holes should have -Z values in the normals.
          If ContainsText(SL.Strings[x], 'vn ') then
          begin
            If RightStr(SL.Strings[x],2) = '-1' then
            begin
              aWEDRing.isHole := true;
              Memo1.Lines.Add('Changing '+aWedRing.name+' to Hole '+IntToStr(hole_count));
              aWedRing.name := 'Hole '+IntToStr(hole_count);
              Inc(hole_count);
            end;
          end
          else
          begin

            {Collect all nodes. Add nodes to ring children}

            //start searching for the vertices of the line
            If ContainsText(SL.Strings[x], 'v ') then
            begin

              //vertices are in the format X,Y,Z. Z is elevation and is not needed.
              aWedNode:= TWED_TextureBezierNode.Create;
              aWedNode.id := id_count;
              inc(id_count);
              aWedNode.parent_id := aWedRing.id;
              aWedRing.children.Add(aWedNode.id); //add to child list of parent
              aWedNode.name := 'Node '+IntToStr(NodeCount);
              inc(NodeCount);

              //read X and Y from OBJ line by line
              CurrentLine := SL.Strings[x];
              Location := '';
              y := 3;  //start of the X location in the line is equal to length('v ')+1
              repeat
                Location := Location + CurrentLine[y];
                inc(y);
              until CurrentLine[y] = ' ';  //space delimiter
              aWedNode.Y := StrToFloat(trim(Location));   //sketchup OBJ files have Y first then X.
              //move to next value
              y := y+1;

              Location := '';
              repeat
                Location := Location + CurrentLine[y];
                inc(y);
              until CurrentLine[y] = ' ';
              aWedNode.X := StrToFloat(trim(Location));   //sketchup OBJ files have X following Y.

              //convert XY location to lat/long and store in record
              {Coordinates := get_new_coordinates_vincenty(central_coord,aWedNode.X, aWedNode.Y);}
              Coordinates := get_new_coordinates_haversine(central_coord,aWedNode.X, aWedNode.Y);
              aWedNode.longitude := FloatToStr(Coordinates.long);
              aWedNode.latitude := FloatToStr(Coordinates.lat);

              //read texture verts from next line
              CurrentLine := SL.Strings[x+1];
              If ContainsText(Currentline, 'vt ') then //ensure that this is actually a texture vertex line
              begin
                y := 4;  //start of the X location in the line is equal to length('vt ')+1
                texvert := '';
                repeat
                  texvert := texvert + CurrentLine[y];
                  inc(y);
                until CurrentLine[y] = ' ';
                aWedNode.S := StrToFloat(texvert);       //S and T are interchanged like X and Y. See above.

                 //move to next value
                y := y+1;

                texvert := '';
                repeat
                  texvert := texvert + CurrentLine[y];
                  inc(y);
                until y >= length(CurrentLine); //until End Of Line
                aWedNode.T := StrToFloat(texvert);       //S and T are interchanged like X and Y. See above.

              end
              else  //this is not a texture vertex line
              begin
                //set the S and T values to 0?
                aWedNode.S := 0;
                aWedNode.T := 0;
              end;


              //add Node to List
              WedNodeList.Add(aWedNode);
              Memo1.Lines.Add('WED Node   Name: '+aWedNode.name+'  ID: '+IntToStr(aWedNode.id)+'  Parent ID: '+ IntToStr(aWedNode.parent_id)+'  X,Y: '+FloatToStr(aWedNode.X)+','+FloatToStr(aWedNode.Y)+'  S,T: '+FloatToStr(aWedNode.S)+','+FloatToStr(aWedNode.T)+'  Long,Lat: '+(aWedNode.longitude)+','+(aWedNode.latitude));
              //back to top

            end
            else
              continue;
          end;
      end;
    end;

    //We will now need to catch the "highest" and "lowest" texture vertex for "Texture Top/Bottom/Left/Right"
    For aWEDOrtho in WEDOrthoList do
    begin
      For OrthoChild in aWEDOrtho.children do
      begin
        For aWEDRing in WEDRingList do
        begin
          If aWEDRing.id = OrthoChild then
          begin
            For Ringchild in aWEDRing.children do
            begin
              For aWEDNode in WEDNodeList do
              begin
                If (Ringchild = aWEDNode.id){ and (not aWEDNode.isHole)) }then
                begin
                  If aWedNode.T > aWedOrtho.TexLeft then
                    aWedOrtho.TexLeft := roundto(aWedNode.T,-4);
                  If aWedNode.T < aWedOrtho.TexRight then
                    aWedOrtho.TexRight := roundto(aWedNode.T,-4);
                  If aWedNode.S > aWedOrtho.TexTop then
                    aWedOrtho.TexTop := roundto(aWedNode.S,-4);
                  If aWedNode.S < aWedOrtho.TexBottom then
                    aWedOrtho.TexBottom := roundto(aWedNode.S,-4);
                  break;
                end;
              end;
            end;
            break;
          end;
        end;
      end;
    end;


    //Validate Texture Extemeties. They should be between 0 and 1. Sometimes the OBJ texverts go up to 2 or more
    For aWEDOrtho in WEDOrthoList do
    begin
      If ((aWedOrtho.TexTop > 1) or (aWedOrtho.TexTop < 0)) then
        aWEDOrtho.TexTop := aWEDOrtho.TexTop - round(aWEDOrtho.TexTop);
      If ((aWedOrtho.TexBottom > 1) or (aWedOrtho.TexBottom < 0))  then
        aWEDOrtho.TexBottom := aWEDOrtho.TexBottom - round(aWEDOrtho.TexBottom);
      If ((aWedOrtho.TexLeft > 1) or (aWedOrtho.TexLeft < 0))  then
        aWEDOrtho.TexLeft := aWEDOrtho.TexLeft - round(aWEDOrtho.TexLeft);
      If ((aWedOrtho.TexRight > 1) or (aWedOrtho.TexRight < 0))  then
        aWEDOrtho.TexRight := aWEDOrtho.TexRight - round(aWEDOrtho.TexRight);
      Memo1.Lines.Add('WED Ortho '+aWEDOrtho.name+' Extremeties (Top, Bottom, Left, Right): '+FloatToStr(aWedOrtho.TexTop)+', '+FloatToStr(aWedOrtho.TexBottom)+', '+FloatToStr(aWedOrtho.TexLeft)+', '+FloatToStr(aWedOrtho.TexRight));
    end;


  finally
    SL.Free;
  end;


  {GO through list of rings which are holes}
  For aWedRing in WEDRingList do
  begin
    If aWEDRing.isHole then
    begin
      For aWedOrtho in WedOrthoList do
      begin
        {Remove WedRing from childlist of parent Ortho}
        If aWedOrtho.children.Contains(aWedRing.id) then
        begin
          aWEDOrtho.children.Remove(aWEDRing.id);
          Memo1.Lines.Add('Removing '+aWEDRing.name+' from '+aWedOrtho.name+' child list');
          //check to ensure that the ortho now has no children, so that we can discard it to prevent accidently moving children back under it later.
          If aWedOrtho.children.Count = 0 then
          begin
            Memo1.Lines.Add('Removing Empty WED Ortho '+aWedOrtho.name);
            WedOrthoList.Remove(aWedOrtho);
            //also remove them from the WedPoly children list
            aWedGroup.children.Remove(aWedOrtho.id);
          end;
        end;
        {and place WedRing in orthophoto children list with matching Group}
        If aWedOrtho.Group = aWedRing.Group then
        begin
          aWedOrtho.children.Add(aWedRing.id);
          aWEDRing.parent_id := aWedOrtho.id;
          Memo1.Lines.Add('Moving '+aWEDRing.name+' to '+aWedOrtho.name+' child list');
        end;
      end;
    end;
  end;


  {Delete orthophotos/rings with 0 children and remove from WED Group children list}

  //cleanup Rings without children
  For aWedRing in WedRingList do
  begin
    If aWedRing.children.Count <= 2 then //less than 3 Nodes means it's not a valid ring
    begin
      Memo1.Lines.Add('Removing Empty WED Ring '+aWedRing.name);
      WedRingList.Remove(aWedRing);
      Parent_id := aWedRing.parent_id;
      //also remove them from the WedPoly children list
      For aWedOrtho in WedOrthoList do
      begin
        If aWedOrtho.id = Parent_id then
        begin
          aWedOrtho.children.Remove(aWedRing.id);
          break;
        end;
      end;
    end;
  end;

  //cleanup Orthos without children
  For aWedOrtho in WedOrthoList do
  begin
    If aWedOrtho.children.Count = 0 then
    begin
      Memo1.Lines.Add('Removing Empty WED Ortho '+aWedOrtho.name);
      WedOrthoList.Remove(aWedOrtho);
      //also remove them from the WedPoly children list
      aWedGroup.children.Remove(aWedOrtho.id);
    end;
  end;

end;

procedure TForm1.BackupWEDXML;
var s, backupname: string;
begin
  s := StringReplace((DateToStr(Now)),'/','-',[rfReplaceAll]);
  s := s+'_'+StringReplace((TimeToStr(Now)),':','-',[rfReplaceAll]);
  SetLength(s,length(s)-3);
  backupname := WEDXMLEdit.Text;
  backupname.Insert(length(backupname)-4,'.'+s);
  CopyFile(pchar(WEDXMLEdit.text), pchar(backupname), true);
end;

procedure TForm1.BuildObjList;

var
  SL: TStringList;
  x: integer;
  s, GUID: string;
  //anotherWEDObjPlacement: TWED_ObjPlacement;

begin



  //initialize unique next ID number from WED XML
  id_count:= GetTextCount(WEDXMLEdit.Text, ' id="', '"')+1;      //+1 to make space for new WED_Group
  existing_elements := id_count-1;
  Memo1.Lines.Add('Highest ID value in earth.wed.xml is '+IntToStr(existing_elements));

  WedGroupList := TObjectList<TWED_Group>.create;


  {------------------OBJECT PLACEMENTS------------------}


  //initialize the WED Group
  aWedGroup:= TWED_Group.Create;
  aWedGroup.id := id_count;
  inc(id_count);
  aWedGroup.parent_id := 4; //4 = world
//  aWedGroup.parent_id := StrToInt(ReturnStringBetween('<object class="WED_Airport" id="','"', WEDXMLEdit.Text));        //We are looking for the Airport Group Id
  aWedGroup.name := 'Objects';
  AWedGroup.children := TList<Integer>.create;  //create empty list for children to be added later
  WedGroupList.Add(aWedGroup);
  Memo1.Lines.Add('WED Group  ID: '+IntToStr(aWedGroup.id)+'  Name: '+ aWedGroup.name+'  Parent ID: '+ IntToStr(aWedGroup.parent_id));



  ObjPlacementList := TObjectList<TWED_ObjPlacement>.create;


  If UseXMLBtn.Caption = 'Cancel' then //XML is loaded
  begin
    {if using XML use these values
    load XML
    for every SceneryObject record build ObjPlacementList
    convert Lat/long from dd mm.mm to dd.dd
    for every ModelData match GUID to MDL name}
    SL := TStringList.Create;
    try
      SL.LoadFromFile(ObjMemo.Lines[0]);
      For x := 1 to SL.Count-1 do
      begin
        If ContainsText(SL.Strings[x],'<SceneryObject') then
        begin
          aWEDObjPlacement := TWED_ObjPlacement.Create;
          aWEDObjPlacement.id := id_count;
          inc(id_count);
          aWEDObjPlacement.parent_id := aWEDGroup.id;
          aWEDGroup.children.Add(aWEDObjPlacement.id);
        end;

        If ContainsText(SL.Strings[x],'altitudeIsAgl=') then
          aWEDObjPlacement.customMSL := not StrToBool(ReturnStringBetweenText('"','"',SL.Strings[x]));
        If ContainsText(SL.Strings[x],'alt=') then
          aWEDObjPlacement.MSL := ReturnStringBetweenText('"','"',SL.Strings[x]);
        If ContainsText(SL.Strings[x],'lat=') then
          aWEDObjPlacement.latitude := DeegreesMinutesToDecimalDegrees(ReturnStringBetweenText('"','"',SL.Strings[x]));
        If ContainsText(SL.Strings[x],'lon=') then
          aWEDObjPlacement.longitude := DeegreesMinutesToDecimalDegrees(ReturnStringBetweenText('"','"',SL.Strings[x]));
        If ContainsText(SL.Strings[x],'heading=') then
          aWEDObjPlacement.heading := ReturnStringBetweenText('"','"',SL.Strings[x]);
        If ContainsText(SL.Strings[x],'name=') then
        begin
          aWEDObjPlacement.name := ReturnStringBetweenText('{','}',SL.Strings[x]);
          ObjPlacementList.Add(aWEDObjPlacement);
        end;
      end;

      //Match GUIDs to names
      For x := 1 to SL.Count-1 do
      begin
        If ContainsText(SL.Strings[x],'GUID') then
        begin
          For aWEDObjPlacement in ObjPlacementList do
          begin
            If aWEDObjPlacement.name = ReturnStringBetweenText('{','}',SL.Strings[x]) then
            begin
              aWEDObjPlacement.name := StringReplace(ExtractFileName(ReturnStringBetweenText('"','"',SL.Strings[x+2])),'mdl','obj',[]);
              aWEDObjPlacement.resource := ObjPathEdit.Text+'\'+aWEDObjPlacement.name;
              Memo1.Lines.Add('WED Object  ID: '+IntToStr(aWEDObjPlacement.id)+'  Name: '+ aWEDObjPlacement.name+'  MSL: '+ aWEDObjPlacement.msl+'  Lat: '+ aWEDObjPlacement.latitude+'  Lon: '+ aWEDObjPlacement.longitude+'  Heading: '+ aWEDObjPlacement.heading+'  Parent ID: '+ IntToStr(aWEDObjPlacement.parent_id));
            end;
          end;
        end;
      end;
    finally
      SL.Free
    end;


  end
  else
  begin
    {else use user input
    Create an ObjectList
    For each object in ObjMemoList
    create a new WEDObjectPLacement
    Add its fields from the edits
    Add the object to the list}
    For s in OBJMemo.Lines do
    begin
      aWEDObjPlacement := TWED_ObjPlacement.Create;
      aWEDObjPlacement.name := TPath.GetFileNameWithoutExtension(s)+'.obj';
      aWEDObjPlacement.id := id_count;
      inc(id_count);
      aWEDObjPlacement.parent_id := aWEDGroup.id;
      aWEDGroup.children.Add(aWEDObjPlacement.id);
      aWEDObjPlacement.customMSL := SetMSLCheckBox.Checked;
      aWEDObjPlacement.MSL := MSLEdit.Text;
      aWEDObjPlacement.latitude := OBJLatEdit.Text;
      aWEDObjPlacement.longitude := OBJLongEdit.Text;
      aWEDObjPlacement.resource := ObjPathEdit.Text+'\'+aWEDObjPlacement.name;
      aWEDObjPlacement.heading := HeadingEdit.Text;

      Memo1.Lines.Add('WED Object  ID: '+IntToStr(aWEDObjPlacement.id)+'  Name: '+ aWEDObjPlacement.name+'  Parent ID: '+ IntToStr(aWEDObjPlacement.parent_id));
      ObjPlacementList.Add(aWEDObjPlacement);
    end;
  end;

end;

procedure TForm1.BuildADEList;

var
  SL: TStringList;
  x: integer;
  value, ShortRampCode, radius, StartNode, EndNode: string;

const
  RampTypes: array [0..6] of string = ('RAMP_GA','RAMP_CA','RAMP_MI','GATE','DOCK_GA','FUEL','VEHICLE');
  TaxiTypes: array [0..4] of string = ('TAXI','PATH','RUNWAY','PARKING','VEHICLE');
  TruckTypes: array[0..7] of string = ('Baggage Loader','Baggage Train', 'Fuel Truck (Jets)', 'Fuel Truck (Liners)', 'Fuel Truck (Props)', 'Catering Truck', 'Ground Power Unit', 'Pushback');

begin

  //initialize unique next ID number from WED XML
  id_count:= GetTextCount(WEDXMLEdit.Text, ' id="', '"')+1;      //+1 to make space for new WED_Group
  existing_elements := id_count-1;
  Memo1.Lines.Add('Highest ID value in earth.wed.xml is '+IntToStr(existing_elements));

  WedGroupList := TObjectList<TWED_Group>.create;
  {------------------PARKING SPACES------------------}



  //initialize the WED Group
  aWedGroup:= TWED_Group.Create;
  aWedGroup.id := id_count;
  inc(id_count);
  aWedGroup.parent_id := 4; //4 = world
//  aWedGroup.parent_id := StrToInt(ReturnStringBetween('<object class="WED_Airport" id="','"', WEDXMLEdit.Text));        //We are looking for the Airport Group Id
  aWedGroup.name := 'Ramp Starts';
  AWedGroup.children := TList<Integer>.create;  //create empty list for children to be added later
  WedGroupList.Add(aWedGroup);
  Memo1.Lines.Add('WED Group  ID: '+IntToStr(aWedGroup.id)+'  Name: '+ aWedGroup.name+'  Parent ID: '+ IntToStr(aWedGroup.parent_id));

  //open OBJ file to begin searching for line groups which will become Wed Rings
  SL := TSTringList.Create;
  WedRampList := TObjectList<TWED_RampPosition>.Create;
  TruckParkingList := TObjectList<TWED_TruckParkingLocation>.Create;
  try

    SL.LoadFromFile(ParkingXMLEdit.Text);
    For x := GetHeaderCommentSize(ParkingXMLEdit.Text, '#') to SL.Count-1 do    //First 3 lines are usually comments
    begin

      //Search for 'TaxiwayParking'
      If ContainsText(SL.Strings[x], 'TaxiwayParking') then
      begin
        aWedRamp:= TWED_RampPosition.Create;
        aWedRamp.id := id_count;
        inc(id_count);
        aWedRamp.parent_id := aWedGroup.id;
        aWedGroup.children.Add(aWedRamp.id); //add to child list of parent
        aWedRamp.TrafficBinary := '000100';

        {set Ramp fields from next lines}

        aWedRamp.index := ReturnStringBetweenText('"','"',SL.Strings[x+1]);
        aWedRamp.name := ReturnStringBetweenText('"','"',SL.Strings[x+7])+' '+ReturnStringBetweenText('"','"',SL.Strings[x+8]);       //add gate number on next line to name
        aWedRamp.heading := ReturnStringBetweenText('"','"',SL.Strings[x+4]);
        aWedRamp.lat := ReturnStringBetweenText('"','"',SL.Strings[x+2]);
        aWedRamp.long := ReturnStringBetweenText('"','"',SL.Strings[x+3]);

        {Traffic Binary determines equipment type:
        1 - Heavy Jets
        1 - Jets
        1 - TurboProps
        1 - Props
        1 - Helis
        1 - Fighters
        The total of these binary values will be converted to the WedRamp.traffic value (between 1 and 63)}

        value := ReturnStringBetweenText('"','"',SL.Strings[x+6]); //Use the Parking Type to set AI/User usage and traffic binary

        If ContainsText(value, 'RAMP_GA') then
        begin
              aWedRamp.ramptype := 'Tie-Down';
              aWedRamp.ramp_op_type := 'General Aviation';
              aWedRamp.TrafficBinary := '011110';
        end;
        If ContainsText(value, 'RAMP_CARGO') then
        begin
              aWedRamp.ramptype := 'Gate';
              aWedRamp.ramp_op_type := 'Cargo';
              aWedRamp.TrafficBinary := '011100';
        end;
        If ContainsText(value, 'MIL') then
        begin
              aWedRamp.ramptype := 'Tie-Down';
              aWedRamp.ramp_op_type := 'Military';
              aWedRamp.TrafficBinary := '000011';
        end;
        If ContainsText(value, 'GATE') then
        begin
              aWedRamp.ramptype := 'Gate';
              aWedRamp.ramp_op_type := 'Airline';
              aWedRamp.TrafficBinary := '011100';
        end;
        If (((ContainsText(value, 'DOCK_GA')) or (ContainsText(value, 'FUEL')){ or (ContainsText(value, 'VEHICLE'))})) then
        begin
              aWedRamp.ramptype := 'Misc';
              aWedRamp.ramp_op_type := 'None';
              aWedRamp.TrafficBinary := '000000';
        end;
        If ContainsText(value, 'VEHICLE') then
          aWedRamp.isVehicleParking := true; //we will use this to convert WedRamps to WedTruckParkings later

        {A	<15m	C-172, Baron 58
        B	15-24m	King Air C90
        C	24-36m	B737, A320, MD80
        D	36-52m	B767, A310, MD10
        E	52-65m	B777, B747, A340
        F	65-80m	A380}


        //set width letter according to radius. If size is E or larger set use of Jets and Heavies only as this should be a space for large commercial airliners
        radius := ReturnStringBetweenText('"','"',SL.Strings[x+5]);
        SetLength(radius, length(radius)-1);

        If StrToFloat(radius) >= 65 then
        begin
          aWedRamp.TrafficBinary := '110000';
          aWedRamp.width_letter := 'F';
        end
        else
        begin
          If StrToFloat(radius) >= 52 then
          begin
            aWedRamp.TrafficBinary := '110000';
            aWedRamp.width_letter := 'E';
          end
          else
          begin
            If StrToFloat(radius) >= 36 then
            begin
              aWedRamp.width_letter := 'D';
            end
            else
            begin
              If StrToFloat(radius) >= 24 then
              begin

                aWedRamp.width_letter := 'C';
              end
              else
              begin
                If StrToFloat(radius) >= 15 then
                begin

                  aWedRamp.width_letter := 'B';
                end
                else
                begin

                  aWedRamp.width_letter := 'A';
                end;
              end;
            end;
          end;
        end;

        If ContainsText(SL.Strings[x+9], 'airlineCodes') then
          aWedRamp.airlines := StringReplace(ReturnStringBetweenText('"','"',SL.Strings[x+9]),',','',[rfReplaceAll]); //remove commas, airlines separated by spaces

        {add to list}
        WedRampList.add(aWedRamp);
        Memo1.Lines.Add('WED Ramp  ID: '+IntToStr(aWedRamp.id)+'  Name: '+ aWedRamp.name+'  Type: '+ aWedRamp.ramptype+'  Width: '+ aWedRamp.width_letter+'  Parent ID: '+ IntToStr(aWedRamp.parent_id));
      end;
    end;
  finally
    SL.Free;
  end;

  //cleanup unused (fuel) spots and convert vehicle parking sports to TWED_TruckParkingLocation
  For x := WedRampList.Count-1 downto 0 do
  begin
    aWedRamp := WedRampList[x];
    If ((aWedRamp.ramptype = 'Misc') and (aWedRamp.ramp_op_type = 'None')) then
    begin
      Memo1.Lines.Add('Removing Unused Wed_Ramp '+aWedRamp.name);
      aWedGroup.children.Remove(aWedRamp.id);
      WedRampList.Remove(aWedRamp);
    end;

    {Create WEDTruckParkings from WEDRamps that had parking types of 'VEHICLE' and remove thenow unused WEDRamps}
    If aWedRamp.isVehicleParking = true then
    begin
      aWEDTruckParking:= TWED_TruckParkingLocation.Create;
      aWEDTruckParking.id := aWedRamp.id; //reuse the old WEDRamp ID instead of creating a new one.
      aWEDTruckParking.parent_id := aWedRamp.parent_id; //That way we can keep the IDs in the correct parent/children relationships as well

      {set Taxi Node fields from WedRamp fields}
      aWEDTruckParking.Name := 'VP'+aWedRamp.index;
      aWEDTruckParking.heading := aWedRamp.heading;
      aWEDTruckParking.latitude := aWedRamp.lat;
      aWEDTruckParking.longitude := aWedRamp.long;
      aWEDTruckParking.trucktype := TruckTypes[random(8)];  //choose a random truck type to place at this location since ADE/FSX/P3D do not specify which vehicles go at truck locations. They are most often fuel trucks though IN FSX/P3D though.

      TruckParkingList.add(aWEDTruckParking);
      Memo1.Lines.Add('WED Truck Parking from Vehicle Parking  ID: '+IntToStr(aWEDTruckParking.id)+'  Random* Type: '+ aWEDTruckParking.trucktype+'  Name: '+ aWEDTruckParking.Name+'  Parent ID: '+ IntToStr(aWEDTruckParking.parent_id));

      WedRampList.delete(x);
    end;
  end;

  {------------------TAXI POINTS------------------}

  //initialize the WED Group
  aWedGroup:= TWED_Group.Create;
  aWedGroup.id := id_count;
  inc(id_count);
  aWedGroup.parent_id := 4; //4 = world
//  aWedGroup.parent_id := StrToInt(ReturnStringBetween('<object class="WED_Airport" id="','"', WEDXMLEdit.Text));         //We are looking for the Airport Group Id
  aWedGroup.name := 'Taxi Routes';
  AWedGroup.children := TList<Integer>.create;  //create empty list for children to be added later
  WedGroupList.Add(aWedGroup);
  Memo1.Lines.Add('WED Group  ID: '+IntToStr(aWedGroup.id)+'  Name: '+ aWedGroup.name+'  Parent ID: '+ IntToStr(aWedGroup.parent_id));

  //open OBJ file to begin searching for line groups which will become Wed Rings
  SL := TSTringList.Create;
  TaxiNodeList := TObjectList<TWED_TaxiRouteNode>.Create;
  TaxiRouteList := TObjectList<TWED_TaxiRoute>.Create;

  {Add Previously created Parking Spaces to TaxiNodeList as Taxi Points we will terminate at. We will denote these with a 'P'}
  If WedRampList <> nil then
  begin
    For aWedRamp in WedRampList do
    begin
      aWEDTaxiNode:= TWED_TaxiRouteNode.Create;
      aWEDTaxiNode.id := id_count;
      inc(id_count);
      aWEDTaxiNode.parent_id := aWedGroup.id;
      aWedGroup.children.Add(aWEDTaxiNode.id); //add to child list of parent

      {set Taxi Node fields from WedRamp fields}
      aWEDTaxiNode.Name := 'P'+aWedRamp.index;
      aWEDTaxiNode.taxinodetype := 'PARKING';
      aWEDTaxiNode.latitude := aWedRamp.lat;
      aWEDTaxiNode.longitude := aWedRamp.long;

      aWEDTaxiNode.viewers := TList<integer>.create;

      TaxiNodeList.add(aWEDTaxiNode);
      Memo1.Lines.Add('WED Taxi Node from Parking Space  ID: '+IntToStr(aWEDTaxiNode.id)+'  Type: '+ aWEDTaxiNode.taxinodetype+'  Name: '+ aWEDTaxiNode.Name+'  Parent ID: '+ IntToStr(aWEDTaxiNode.parent_id));
    end;
  end;

  {Now create rest of TaxiPoints from XML file}
  try

    SL.LoadFromFile(ParkingXMLEdit.Text);
    For x := GetHeaderCommentSize(ParkingXMLEdit.Text, '#') to SL.Count-1 do    //First 3 lines are usually comments
    begin

      //Search for 'TaxiwayPoint'
      If ContainsText(SL.Strings[x], 'TaxiwayPoint') then
      begin
        aWEDTaxiNode:= TWED_TaxiRouteNode.Create;
        aWEDTaxiNode.id := id_count;
        inc(id_count);
        aWEDTaxiNode.parent_id := aWedGroup.id;
        aWedGroup.children.Add(aWEDTaxiNode.id); //add to child list of parent

        {set Taxi Node fields from next lines}
        aWEDTaxiNode.Name := ReturnStringBetweenText('"','"',SL.Strings[x+1]);
        aWEDTaxiNode.taxinodetype := ReturnStringBetweenText('"','"',SL.Strings[x+2]);
        aWEDTaxiNode.latitude := ReturnStringBetweenText('"','"',SL.Strings[x+4]);
        aWEDTaxiNode.longitude := ReturnStringBetweenText('"','"',SL.Strings[x+5]);

        aWEDTaxiNode.viewers := TList<integer>.create;

        TaxiNodeList.add(aWEDTaxiNode);
        Memo1.Lines.Add('WED Taxi Node  ID: '+IntToStr(aWEDTaxiNode.id)+'  Type: '+ aWEDTaxiNode.taxinodetype+'  Name: '+ aWEDTaxiNode.Name+'  Parent ID: '+ IntToStr(aWEDTaxiNode.parent_id));
      end;

        {------------------TAXI PATHS------------------}

      //Search for 'TaxiwayRoutes'
      If ContainsText(SL.Strings[x], 'TaxiwayPath') then
      begin
        aWEDTaxiRoute:= TWED_TaxiRoute.Create;
        aWEDTaxiRoute.id := id_count;
        inc(id_count);
        aWEDTaxiRoute.parent_id := aWedGroup.id;
        aWedGroup.children.Add(aWEDTaxiRoute.id); //add to child list of parent

        {set Taxi Node fields from next lines}
        If IndexStr(ReturnStringBetweenText('"','"',SL.Strings[x+1]), TaxiTypes)<=3 then
          aWEDTaxiRoute.vehicle_class := 'Aircraft'
        else
           aWEDTaxiRoute.vehicle_class := 'Ground Trucks';

        //set name, if the type of taxipath is runway, check to see if there is a runway designator and add it
        aWEDTaxiRoute.name := ReturnStringBetweenText('"','"',SL.Strings[x+1])+' '+ReturnStringBetweenText('"','"',SL.Strings[x+9]);
        If ReturnStringBetweenText('"','"',SL.Strings[x+1]) = 'Runway' then
        begin
          If ReturnStringBetweenText('"','"',SL.Strings[x+10]) <> 'None' then
            aWEDTaxiRoute.name := aWEDTaxiRoute.name+ReturnStringBetweenText('"','"',SL.Strings[x+10]);
        end;

        //set width letter from radius
        radius := ReturnStringBetweenText('"','"',SL.Strings[x+4]);
        SetLength(radius, length(radius)-1);
        If StrToFloat(radius) >= 65 then
          aWEDTaxiRoute.width_letter := 'F'
        else
        begin
          If StrToFloat(radius) >= 52 then
            aWEDTaxiRoute.width_letter := 'E'
          else
          begin
            If StrToFloat(radius) >= 36 then
              aWEDTaxiRoute.width_letter := 'D'
            else
            begin
              If StrToFloat(radius) >= 24 then
                aWEDTaxiRoute.width_letter := 'C'
              else
              begin
                If StrToFloat(radius) >= 15 then
                  aWEDTaxiRoute.width_letter := 'B'
                else
                  aWEDTaxiRoute.width_letter := 'A';
              end;
            end;
          end;
        end;

        aWEDTaxiRoute.sources := TList<integer>.create;
        StartNode := ReturnStringBetweenText('"','"',SL.Strings[x+2]);
        EndNode := ReturnStringBetweenText('"','"',SL.Strings[x+3]);
        If ReturnStringBetweenText('"','"',SL.Strings[x+1])='PARKING' then
          EndNode := 'P'+EndNode; //add a P to the beginning of the index/name to denote that this path terminates at a parking point
        For aWEDTaxiNode in TaxiNodeList do
        begin
          If (aWEDTaxiNode.name = StartNode) or (aWEDTaxiNode.name = EndNode) then
          begin
            aWEDTaxiRoute.sources.Add(aWEDTaxiNode.id);
            aWEDTaxiNode.viewers.Add(aWEDTaxiRoute.id)
          end;
        end;

        TaxiRouteList.add(aWEDTaxiRoute);
        Memo1.Lines.Add('WED Taxi Route  ID: '+IntToStr(aWEDTaxiRoute.id)+'  Name: '+ aWEDTaxiRoute.name+'  Type: '+ aWEDTaxiRoute.vehicle_class+'  Width: '+ aWEDTaxiRoute.width_letter+'  Parent ID: '+ IntToStr(aWEDTaxiRoute.parent_id));
      end;


    end;

    //cleanup Taxi Routes with no sources
    For x := TaxiRouteList.Count-1 downto 0 do
    begin
      aWEDTaxiRoute := TaxiRouteList[x];
      If aWEDTaxiRoute.sources.Count <> 2 then
      begin
        Memo1.Lines.Add('Removing TaxiRoute '+aWEDTaxiRoute.name+' ('+IntToStr(aWEDTaxiRoute.ID)+'). Number of sources does not equal 2. Instead it had '+IntToStr(aWEDTaxiRoute.sources.Count));
        aWedGroup.children.Remove(aWEDTaxiRoute.id);
        TaxiRouteList.Remove(aWEDTaxiRoute);
      end;
    end;
    //cleanup Taxi Nodes with no viewers
    For x := TaxiNodeList.Count-1 downto 0 do
    begin
      aWEDTaxiNode := TaxiNodeList[x];
      If aWEDTaxiNode.viewers.Count = 0 then
      begin
        Memo1.Lines.Add('Removing Unused TaxiNode '+aWEDTaxiNode.name);
        aWedGroup.children.Remove(aWEDTaxiNode.id);
        TaxiNodeList.Remove(aWEDTaxiNode);
      end;
    end;
  finally
    SL.Free;
  end;

end;

procedure TForm1.BuildLineList;

var SL: TStringList;
    x,y,z, child, gMeshCount, ClosedCount, OpenCount, index, connecting_index, iteration, WedLineIndex, i: integer;
    SearchString, CurrentLine, Location, l, s: string;
    Coordinates, central_coord: TCoordinate;
    TempList: TList<integer>;
    SplitWedLineList: TObjectList<TWed_LinePlacement>;
    aSearchDirection: TDirection;
    anotherWedLine: TWED_LinePlacement;
    aDuplicateWedLineNode: TWED_SimpleBezierBoundaryNode;

begin
  {Order of Operations:
  Collect all verts
  scan for mesh model, create new group, scan for line segment, add to group
  for each group in group list do, start with first line segment, find connecting segment, remove from list, repeat until group is emtpy.
  if no connecting segment is found, create new line}
  WedGroupList := TObjectList<TWED_Group>.create;


  //initialize unique next ID number from WED XML
  NodeCount := 1;
  id_count:= GetTextCount(WEDXMLEdit.Text, ' id="', '"')+1;      //+1 to make space for new WED_Group
  existing_elements := id_count-1;
  Memo1.Lines.Add('Highest ID value in earth.wed.xml is '+IntToStr(existing_elements));

  //central coordinates record
  central_coord.long := StrToFloat(LongEdit.Text);
  central_coord.lat := StrToFloat(LatEdit.Text);

  //initialize the WED Group
  aWedGroup:= TWED_Group.Create;
  aWedGroup.id := id_count;
  inc(id_count);
  aWedGroup.parent_id := 4;        //4 = world
  aWedGroup.name := 'GP Lines';
  AWedGroup.children := TList<Integer>.create;  //create empty list for children to be added later
  WedGroupList.Add(aWedGroup);
  Memo1.Lines.Add('WED Group  ID: '+IntToStr(aWedGroup.id)+'  Name: '+ aWedGroup.name+'  Parent ID: '+ IntToStr(aWedGroup.parent_id));

  //open OBJ file to begin searching for line groups which will become Wed Rings
  SL := TSTringList.Create;
  WedLineList := TObjectList<TWed_LinePlacement>.Create;
  SplitWedLineList := TObjectList<TWed_LinePlacement>.Create;
  WedLineNodeList := TObjectList<TWED_SimpleBezierBoundaryNode>.Create;
  try

    SL.LoadFromFile(OBJEdit.Text);

    For x := GetHeaderCommentSize(OBJEdit.Text, '#') to SL.Count-1 do //First 3 lines are usually comments
    begin
      If ContainsText(SL.Strings[x], 'v ') then
      begin
        //vertices are in the format X,Y,Z. Z is elevation and is not needed.
        aWedLineNode:= TWED_SimpleBezierBoundaryNode.Create;
        aWedLineNode.id := id_count;
        inc(id_count);
        aWedLineNode.name := 'Node '+IntToStr(NodeCount);
        aWedLineNode.vertex := NodeCount;
        inc(NodeCount);

        //read X and Y from OBJ line by line
        CurrentLine := SL.Strings[x];
        Location := '';
        y := 3;  //start of the X location in the line is equal to length('v ')+1
        repeat
          Location := Location + CurrentLine[y];
          inc(y);
        until CurrentLine[y] = ' ';  //space delimiter
        aWedLineNode.Y := StrToFloat(trim(Location));   //sketchup OBJ files have Y first then X.
        //move to next value
        y := y+1;

        Location := '';
        repeat
          Location := Location + CurrentLine[y];
          inc(y);
        until CurrentLine[y] = ' ';
        aWedLineNode.X := StrToFloat(trim(Location));   //sketchup OBJ files have X following Y.

        //convert XY location to lat/long and store in record
        {Coordinates := get_new_coordinates_haversine(central_coord,aWedNode.X, aWedNode.Y);}
        Coordinates := get_new_coordinates_haversine(central_coord,aWedLineNode.X, aWedLineNode.Y);
        aWedLineNode.longitude := FloatToStr(Coordinates.long);
        aWedLineNode.latitude := FloatToStr(Coordinates.lat);

        //add Node to List
        WedLineNodeList.Add(aWedLineNode);
        Memo1.Lines.Add('WED Line Node   Name: '+aWedLineNode.name+'  ID: '+IntToStr(aWedLineNode.id)+'  Parent ID: '+ IntToStr(aWedLineNode.parent_id)+'  X,Y: '+FloatToStr(aWedLineNode.X)+','+FloatToStr(aWedLineNode.Y)+'  Long,Lat: '+(aWedLineNode.longitude)+','+(aWedLineNode.latitude));
        //back to top
      end;
    end;

    {Search for G Mesh which will become lines}
    //initialize new Line Segment Ids
    gMeshCount := 0;
    ClosedCount := 0;
    OpenCount := 0;
    //for every 'g Mesh' we find we will create a new Line Placement
    For x := GetHeaderCommentSize(OBJEdit.Text, '#') to SL.Count-1 do //First 3 lines are usually comments
    begin
      //Search for 'Mesh'
      If ContainsText(SL.Strings[x], 'Mesh') then
      begin
        inc(gMeshCount);

        {Create new WED_LinePlacemet for each Line}

        NewWedLine(nil, nil, WedLineList);
      end
      else
      begin
        //scan for line segment
        If ContainsText(SL.Strings[x], 'l ') then
        begin
          z := length(SL.Strings[x]);
          l := '';
          While (SL.Strings[x])[z] <> ' ' do   //read last number on line
          begin
            l := (SL.Strings[x])[z] + l;
            z := z-1;
          end;

          aWedLine.LineEndList.Add(StrToInt(l));
          aWedLine.LineStartList.Add(StrToInt(ReturnStringBetweenText(' ',' ',SL.Strings[x])));   //read middle number on line
        end;
      end;
    end;
  finally
    SL.Free;
  end;

  {We now have a list of all verts, a list of WEDLines, and a list of LineSegment Starts and Ends where each linesegment is linked to a WedLine. Start and End values are the same as vertex values}

  {start with first segment in group
  if WEDLine children is not empty create new WEDLine, this means we have vertices shared among multiple lines?
  add segment index to temp list
  find connecting segment
  add connecting segment to temp list until we have iterated length(WedLine.segment_list) times  or connecting segment cannot be found
  add all start vertices in TempList and end vertice of last element to WEDLine children
  remove all indexed elements in temp list from line segment group lists

  if start vert = end vert then WEDLine is closed.
  start over}

  WedLineIndex :=0;
  IndexList := TList<integer>.create;
  While WedLineIndex <= WedLineList.Count-1 do
  begin
    aWedLine := WedLineList[WedLineIndex];
    index:=aWedLine.LineStartList.Count-1;
    iteration:=0;
    aSearchDirection := FromEnd;
    SwitchSearchDirection(aSearchDirection);

    repeat
      inc(iteration);
      aWedLine.children.Add(aWedLine.LineStartList[index]); //add start vertex to WEDLine children
      IndexList.Add(index);

      connecting_index := aWedLine.LineStartList.IndexOf(aWedLine.LineEndList[index]);  //find connecting segment

      {If connecting index not found and length of line = 1 then
      search backwards procedure:
      remove last added child
      switch line start and line end lists
      search again
      If connecting index still not found
      switch back lists and continue to split?}

      If ((connecting_index = -1) and (aWedLine.children.Count <= 1) and (aSearchDirection = FromEnd)) then   //if we just started a new line and cant find a connecting index then start searching forwards instead
      begin
        aSearchDirection := FromBeginning;
        SwitchSearchDirection(aSearchDirection);
        dec(iteration);
        continue;
      end;


      If connecting_index = -1 then //no connecting segment found
      begin

        aWedLine.children.Add(aWedLine.LineEndList[index]); //and end vertex of last element to WEDLine children

        If aSearchDirection = FromBeginning then   //if we have searched forwards and cant find a connecting index then switch back to searching backwards and continue.
        begin
          aSearchDirection := FromEnd;
          SwitchSearchDirection(aSearchDirection);
        end;

        If iteration = aWedLine.LineStartList.Count then
          break
        else
        begin
          {if we break here that means we have not found a connecting segment but there are still more vertices.
          We need to split the line and move the rest of the vertices to a new wedline and come back to it later.}

          SplitWedLine(aWedLine, indexlist);

          break;
        end;


      end
      else   //connecting segment found
      begin

        If iteration = aWedLine.LineStartList.Count then   //if end of list
        begin
          aWedLine.children.Add(aWedLine.LineEndList[index]); //and end vertex of last element to WEDLine children
          break;
        end
        else
        begin
          If aWedLine.children.Contains(aWedLine.LineStartList[connecting_index]) then    //if the children already contains the connecting index
          begin
            aWedLine.children.Add(aWedLine.LineEndList[index]);
            SplitWedLine(aWedLine, indexlist);
          end;
        end;

        index := connecting_index;

      end;
    until (iteration >= aWedLine.LineStartList.Count);

    inc(WedLineIndex);
    IndexList.Clear;

  end;
  indexlist.Free;

  For aWedLine in WedLineList do   {remove while iterating list leads to skipped elements? investigate}
//  For x := WedLineList.Count-1 downto 0 do
  begin
//    aWedLine := WedLineList[x];

    aWedLine.children.Capacity := aWedLine.children.count;   //free memory

    if aWedLine.children.Count <> 0 then
    begin
      if aWedLine.children.First = aWedLine.children.Last then   //if start vert = end vert then WEDLine is closed.
      begin
        aWedLine.closed := true;
        aWedLine.children.Delete(aWedLine.children.Count-1);   //remove last vertex
        inc(ClosedCount);
      end
      else
        inc(OpenCount);
    end;

    //change any nodes of any WedLines which share vertices with another WedLine
    {Change the first node referenced in LineStartList to a newly created node to avoid duplicate node sharing among lines}
    For aWedLineNode in WedLineNodeList do
    begin
      //find the node to duplicate
      {If aWedLineNode.vertex = aWedLine.children[0] then
        break;  }
    //end;
      If aWedLine.children.Contains(aWedLineNode.vertex) then
      begin
      //search the children of all the other WedLines to see if they contain matching vertices
        For anotherWedLine in WedLineList do
        begin
          If anotherWedLine = aWedLine then
            continue;
          If anotherWedLine.children.Contains(aWedLineNode.vertex) then
          begin
            aDuplicateWedLineNode:= TWED_SimpleBezierBoundaryNode.Create;
            aDuplicateWedLineNode.id := id_count;
            inc(id_count);
            aDuplicateWedLineNode.name := aWedLineNode.name+'_dup';
            aDuplicateWedLineNode.parent_id := aWedLine.id;
            aDuplicateWedLineNode.Y := aWedLineNode.Y;
            aDuplicateWedLineNode.X := aWedLineNode.X;
            aDuplicateWedLineNode.longitude := aWedLineNode.longitude;
            aDuplicateWedLineNode.latitude := aWedLineNode.latitude;
            aDuplicateWedLineNode.vertex := NodeCount;
            inc(NodeCount);
            //add Node to List
            WedLineNodeList.Add(aDuplicateWedLineNode);
            Memo1.Lines.Add('Duplicating WED Line Node   New Name: '+aDuplicateWedLineNode.name+'  new ID: '+IntToStr(aDuplicateWedLineNode.id)+'  new Vertex#: '+IntToStr(aDuplicateWedLineNode.vertex)+'  Parent ID: '+ IntToStr(aDuplicateWedLineNode.parent_id));
            //change reference in LineStartList to new node vertex number determined by number of exisiting elements

            aWedLine.children[aWedLine.children.IndexOf(aWedLineNode.vertex)] := aDuplicateWedLineNode.vertex; //this will be added to the wedlines children and later referenced back to an ID number from a vertex number
            break;
          end;
        end;
      end;
    end;
  end;

  For aWedLine in WedLineList do   {remove while iterating list leads to skipped elements? investigate}
//  For x := WedLineList.Count-1 downto 0 do
  begin
//    aWedLine := WedLineList[x];
    Memo1.Lines.Add('Current WED line ID: '+IntToStr(aWedLine.id));

    s := '';
    For child in aWedLine.children do
      s := s+IntToStr(child)+', ';
    Memo1.Lines.Add('Line vertices are: '+s);

    //change WedLine children from vertex numbers to vertex IDs
    For x := 0 to aWedLine.children.Count-1 do
    begin
      For aWedLineNode in WedLineNodeList do
      begin
        If aWedLineNode.vertex = aWedLine.children[x] then
        begin
          aWedLine.children[x] := aWedLineNode.id; //existing_elements+1+aWedLine.children[x];
          aWedLineNode.parent_id := aWedLine.id;
          break;
        end;
      end;
    end;

    {For x := 0 to aWedLine.children.Count-1 do
    begin
      aWedLine.children[x] := existing_elements+1+aWedLine.children[x];
    end;}

    //cleanup Rings without children
    If aWedLine.children.Count < 2 then //less than 2 Nodes means it's not a valid line
    begin
      Memo1.Lines.Add('Removing Empty Line '+aWedLine.name);
      WedLineList.Remove(aWedLine);
      //also remove them from the WedPoly children list
      aWedGroup.children.Remove(aWedLine.id);
    end;

  end;

  //add the parent_ids of WedLineNodes to the WedLines.id
  For aWedLineNode in WedLineNodeList do
  begin
    For aWedLine in WedLineList do
    begin
      if aWedLine.children.Contains(aWedLineNode.id) then
      begin
        If aWedLineNode.parent_id = 0 then  //if the parent id wasn't set before
        begin
          Memo1.Lines.add('Setting Parent ID of '+IntToStr(aWedLineNode.id)+' to '+IntToStr(aWedLine.id)); //set it
          aWedLineNode.parent_id := aWedLine.id;
          break;
        end;
      end;
    end;
  end;

  For aWedLineNode in WedLineNodeList do
  begin
  //cleanup Nodes without parents
    If aWedLineNode.parent_id = 0 then
    begin
      Memo1.Lines.Add('Removing Unused Node '+aWedLineNode.name);
