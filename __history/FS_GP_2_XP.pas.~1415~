procedure TForm1.MDLNameEdit;
var s,NewName: string;
    FS: TFileStream;
    aSection: TMDLSection;
    b: byte;
    data: Tbytes;
    i, idx, datalength, InsertPosition, InsertLength: integer;

begin

  For s in MDLMemo.Lines do
  begin
    NewName := StringReplace(ExtractFileName(s),'.mdl','',[])+#0;
    //open file read/write
    //read first section label
    //read size of data
    //fead data from 0 to size of data
    //interpret data according to section label
    //next section
    FS:= TFileStream.Create(S, fmOpenReadWrite{ or fmShareDenyWrite});
    try
      While FS.Position < FS.Size do
      begin
        aSection := TMDLSection.Create;
        aSection.data := nil;
        aSection.labelname := '';
        data := nil;
        //read section label
        For i := 1 to 4 do
        begin
          FS.Read(b,sizeof(b));
          SetLength(data, length(data)+1);
          data[High(data)] := b;
        end;
        aSection.labelname := TEncoding.UTF8.GetString(data);

        If aSection.labelname = 'RIFF' then
          //skip header
          FS.Seek(8, soFromCurrent)
        else
        begin
          //read size of data
          FS.Read(aSection.size,sizeof(aSection.size));
          //if this is NOT the MDLN section
          If aSection.labelname <> 'MDLN' then
          //seek forward by size
            FS.Seek(aSection.size,soFromCurrent)
          else
          begin
            //else seek backward by size of int
            FS.Seek(sizeof(integer)*-1,soFromCurrent);
            //integer value size of NewName
            datalength := length(NewName);
            //difference between space left for old name and space required for new name
            InsertLength := datalength-aSection.size;
            //write new data length
            FS.write(datalength, sizeof(datalength));
            //Save current position to come back to later
            InsertPosition := FS.Position;

            {We will need to read all characters from current position + length of oldname (i.e. section.size) to EOF and copy them downwards "Insert" spaces to make space for NewName length}
            //We are now at the beginning of the Section Length integer for MDLN. Seek forward to the next section(i.e PARA)
            FS.Seek(aSection.size, soFromCurrent);
            //prepare array of bytes for rest of file
            data := nil;
            SetLength(data, FS.Size);
            For idx := 1 to length(data) do
              data[idx] := 0;
            //read all characters from current position to EOF and save how many bytes we've read in datalength
            datalength := FS.Read(data, FS.size);
//            ShowMessage(IntToStr(datalength));

            //seek back to insertion point which is beginning of friendly name in MDLN section
            FS.Position := InsertPosition;

            //convert NewName to ch and write
            for idx := 1 to length(NewName) do
            begin
              b := Byte(NewName[idx]);
              FS.Write(b,sizeof(b));
            end;

            //append rest of file
            FS.Write(data, datalength);

            //go back to RIFF header
            Fs.Position := 4;
            //read section size
            FS.Read(aSection.size, sizeof(aSection.size));
            //seek back to beginning of section size
            FS.Seek(sizeof(aSection.size)*-1, soFromCurrent);
            //write new section size (+InsertLength)
            FS.Write((aSection.size+length(newname))), sizeof(aSection.size));
          end;



        end;
        aSection.Free;
      end;
    finally
      FS.Free;
    end;

  end;


