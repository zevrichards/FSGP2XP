//ASSUMES UNITS IN METERS
//https://stackoverflow.com/questions/7222382/get-lat-long-given-current-point-distance-and-bearing
function TForm1.get_new_coordinates_haversine(central_coord:TCoordinate; X,Y: real):Tcoordinate;
const R:real = 6378137;  //Earth Radious in M
var central_lat,central_long,new_lat,new_long,bearing, distance: real;
begin
  //Degrees to Radians
  central_lat := central_coord.lat * (pi/180);
  central_long := central_coord.long * (pi/180);

  bearing := ArcTan2(Y,X);
  distance := sqrt(sqr(X)+sqr(Y));

  new_lat := arcsin(sin(central_lat)*cos(distance/R) + cos(central_lat)*sin(distance/R)*cos(bearing));
  new_long := central_long + arctan2(sin(bearing)*sin(distance/R)*cos(central_lat),cos(distance/R)-sin(central_lat)*sin(new_lat));

  //back to degrees
  new_lat := new_lat * (180/pi);
  new_long := new_long * (180/pi);

  //round to 8 decimal places
  result.lat := roundto(new_lat,-8);
  result.long := roundto(new_long,-8);

end;

//ASSUMES UNITS IN METERS
//https://www.movable-type.co.uk/scripts/latlong-vincenty.html
function TForm1.get_new_coordinates_vincenty(central_coord:TCoordinate; X,Y: real):Tcoordinate;
const SemiMajor:real=6378137.0;       //Semi-major axis
  	  SemiMinor:real=6356752.314245;  //Semi-minor axis
var f,A,B,Ph1,Lambda1,bearing,distance,SinA1,CosA1,TanU1,CosU1,SinU1,Sigma1,SinA,
    CosSqA,USq,Sigma,SinSigma,CosSigma,DeltaSigma,Cos2Sigma,SigmaPrime,Phi1,Phi2,
    Lambda,Lambda2,C,A2,L,new_lat,new_long: real;
    iterations: integer;
begin

  f:=(SemiMajor-SemiMinor)/SemiMajor;

  //Degrees to Radians
  Phi1 := central_coord.lat * (pi/180);
  Lambda1 := central_coord.long * (pi/180);

  bearing := ArcTan2(Y,X);   //in radians
  distance := sqrt(sqr(X)+sqr(Y));   //in meters

  SinA1 := sin(bearing);
  CosA1 := cos(bearing);

  TanU1 := (1-f) * tan(Phi1);
  CosU1 := 1/Sqrt(1+tanU1*tanU1);
  SinU1 := TanU1 * CosU1;
  Sigma1 := ArcTan2(TanU1, CosA1);
  SinA := CosU1 * SinA1;
  CosSqA := 1 - SinA*SinA;
  USq := CosSqA * (SemiMajor*SemiMajor - SemiMinor*SemiMinor)/(SemiMinor*SemiMinor);
  A := 1 + USq/16384*(4096+USq*(-768+USq*(320-175*USq)));
  B := USq/1024 * (256+USq*(-128+USq*(74-47*USq)));

  Sigma := distance/(SemiMinor*A);
  SinSigma := 0;
  CosSigma := 0;
  DeltaSigma := 0;
  Cos2Sigma := 0;

  SigmaPrime := 0;
  Iterations := 0;

  While (Abs(Sigma - SigmaPrime) > 1e-12) and (iterations<100) do
  begin
    cos2Sigma := Cos(2*Sigma1 + Sigma);
    SinSigma := Sin(Sigma);
    CosSigma := Cos(Sigma);
    DeltaSigma := B*SinSigma*(Cos2Sigma+B/4*(CosSigma*(-1+2*Cos2Sigma*Cos2Sigma)-B/6*cos2Sigma*(-3+4*SinSigma*SinSigma)*(-3+4*Cos2Sigma*Cos2Sigma)));
    SigmaPrime := Sigma;
    Sigma := distance/(SemiMinor*A)+DeltaSigma;
    inc(iterations);
  end;

  If iterations >=100 then
    ShowMessage('Vincenty Formula failed to converge');

  x := sinU1*sinSigma - cosU1*CosSigma*CosA1;
  Phi2 := Arctan2(SinU1*CosSigma + CosU1*SinSigma*CosA1, (1-f)*Sqrt(SinA*SinA + x*x));
  Lambda := Arctan2(SinSigma*SinA1, CosU1*CosSigma - SinU1*SinSigma*CosA1);
  C := f/16*CosSqA*(4+f*(4-3*CosSqA));
  L := Lambda - (1-C) * f * sinA * (Sigma + C*SinSigma*(cos2Sigma+C*CosSigma*(-1+2*Cos2Sigma*Cos2Sigma)));
  Lambda2 := Lambda1 + L;

  A2 := Arctan2(SinA, -x);

  //back to degrees
  new_lat := Phi2 * (180/pi);
  new_long := Lambda2 * (180/pi);

  //round to 8 decimal places
  result.lat := roundto(new_lat,-8);
  result.long := roundto(new_long,-8);

end;

