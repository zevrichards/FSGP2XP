procedure TForm1.ValidateBtnClick(Sender: TObject);

type TNodeRecord = record
  id: string;
  index: integer;
end;

var SL: TStringList;
    aNode: TNodeRecord;
    NodesList: TList<TNodeRecord>;
    x,y,z: integer;
    HasDuplicate: boolean;

begin



  SL := TStringList.Create;
  NodesList := TList<TNodeRecord>.create;

  try
    SL.LoadFromFile(WEDXMLEdit.Text);

    {gather all nodes}
    x := 1;
    While x < SL.Count do
    begin
      If ContainsText(SL.Strings[x], 'WED_AirportChain') then
      begin
        x := x+2;
        While ContainsText(SL.Strings[x], 'child ') do
        begin
          aNode.id := ReturnStringBetweenText('id="', '"', SL.Strings[x]);
          aNode.index := x;
          NodesList.Add(aNode);
          inc(x);
        end;
      end
      else
      begin
        inc(x);
      end;
    end;

    If NodesList <> nil then
    begin

      {Sort List by ids}
      NodesList.Sort(TComparer<TNodeRecord>.Construct(
        function (const L, R: TNodeRecord): integer
        begin
           if L.id=R.id then
              Result:=0
           else if L.id< R.id then
              Result:=-1
           else
              Result:=1;
        end
        ));

      Memo1.Lines.Add('----------All nodes---------------');
      For aNode in NodesList do
        Memo1.Lines.Add(aNode.id+' ,'+IntToStr(aNode.index));
      Memo1.Lines.Add('-------------------------');

      {find duplicates, remove others}
      Memo1.Lines.Add('Removing nodes which appear only once...');
      x := NodesList.Count-1;
      While x > 0 do
      begin
        HasDuplicate := false;
        aNode := NodesList[x];
        For y:= 0 to NodesList.Count-1 do
        begin
          If ((aNode.id = NodesList[y].id) and (y<>x)) then  //check to make sure you are not comparing node against itself
          begin
            HasDuplicate := true;
            break;
          end;
        end;
        If HasDuplicate = false then
          NodesList.Delete(x);
        dec(x);
      end;

      If NodesList.Count <=1 then
        exit;
//      //compare first element
//      If NodesList[0].id<>NodesList[1].id then
//          NodesList.Delete(0);

      Memo1.Lines.Add('----------Duplicate nodes---------------');
      For aNode in NodesList do
        Memo1.Lines.Add(aNode.id+' ,'+IntToStr(aNode.index));

      {Sort List by indexes}
      NodesList.Sort(TComparer<TNodeRecord>.Construct(
        function (const L, R: TNodeRecord): integer
        begin
           if L.index=R.index then
              Result:=0
           else if L.index< R.index then
              Result:=-1
           else
              Result:=1;
        end
        ));

      {find duplicates, remove others}
      Memo1.Lines.Add('---------Sorted by Index----------------');
      For aNode in NodesList do
        Memo1.Lines.Add(aNode.id+' ,'+IntToStr(aNode.index));

      {delete duplicate children nodes from parent lines}
      For x := NodesList.Count-1 downto 0 do
      begin
        Memo1.Lines.add('Deleting Line '+IntToStr(NodesList[x].index));
        SL.Delete(NodesList[x].index);
      end;

      {delete nodes}
      For aNode in NodesList do
      begin
        For x := 0 to SL.Count-1 do
        begin
          If ContainsText(SL.Strings[x], 'class="WED_AirportNode" id="'+aNode.id+'"') then
          begin
            Memo1.Lines.add('Deleting Object class="WED_AirportNode" id="'+aNode.id+'"');
            z := x;
            While not ContainsText(SL.Strings[z], '</object>') do //find end of object
              inc(z);
            For y:= z downto x do
              SL.Delete(y);
            break;
          end
        end;
      end;
      BackupWEDXML;
      SL.SaveToFile(WEDXMLEdit.Text);

      ValidateWEDXML;
    end;
  finally
    SL.Free;
  end;

end;

procedure TForm1.ValidateWEDXML;
var SL: TStringList;
    w,x,y,z: integer;
    id: string;

begin

  SL := TStringList.Create;
  try
    SL.LoadFromFile(WEDXMLEdit.Text);

    {Search for objects with empty children, remove them from their parents and delete them}
    x:=0;
    While x < SL.Count do
    begin
      If ContainsText(SL.Strings[x],'<children>') then
      begin
        If ContainsText(SL.Strings[x+1],'</children>') then
        begin

          id := ReturnStringBetweenText(' id="','"', SL.Strings[x-1]);
          Memo1.Lines.Add('Found invalid object id '+id+'. Proceeding to remove');
          //parent_id := ReturnStringBetweenText(' parent_id="','"', SL.Strings[x]);
          {Delete from any parents}
          For y := SL.Count-1 downto 0 do
          begin
            If ContainsText(SL.Strings[y],'<child id="'+id+'"/>') then
            begin
              Memo1.Lines.Add('Removing child '+id+' from parent');
              SL.Delete(y);
            end;
          end;

          {Delete invalid object}
          y := x-2;
{//I honestly don't know why this is not x-1 because the object starts on the line above but the program does not delete it.}
          z := x;
          While not ContainsText(SL.Strings[z], '</object>') do //find end of object
            inc(z);

          Memo1.Lines.Add('Deleting object between lines'+IntToStr(y)+' and '+IntToStr(z));
          For w := z downto y do
            SL.Delete(w);
        end;
      end;
      inc(x);
    end;

    SL.SaveToFile(WEDXMLEdit.Text);
  finally
    SL.Free;
  end;

end;

