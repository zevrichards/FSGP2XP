  aWedLine:= TWED_LinePlacement.Create;
  aWedLine.id := id_count;
  inc(id_count);
  aWedLine.parent_id := aWedGroup.id;
  aWedGroup.children.Add(aWedLine.id); //add to child list of parent
  aWedLine.name := TPath.GetFileNameWithoutExtension(OBJEdit.Text)+'_'+IntToStr(id_count-1);
  aWedLine.resource := PolPathEdit.Text+'\' + PolEdit.Text +'.lin';
  aWedLine.children := TList<Integer>.create;  //create empty list for children to be added later
  aWedLine.LineStartList := TList<Integer>.create;
  aWedLine.LineEndList := TList<Integer>.create;
  If LineStartList <> nil then
    aWedLine.LineStartList.AddRange(LineStartList);
  If LineEndList <> nil then
    aWedLine.LineEndList.AddRange(LineEndList);

  aWedLine.closed := false;
  aWedLineList.add(aWedLine);
  Memo1.Lines.Add('WED Line  ID: '+IntToStr(aWedLine.id)+'  Parent ID: '+ IntToStr(aWedLine.parent_id)+'  Name/Resource: '+aWedLine.name);
end;

procedure TForm1.SplitWedLine(aWedLine: TWED_LinePlacement; indexlist: TList<integer>);
var x: integer;
begin
  indexlist.Sort;
  indexlist.Reverse;
  For x in indexlist do
  begin
    aWedLine.LineStartList.delete(x);
    aWedLine.LineEndList.delete(x);
  end;

  NewWedLine(aWedLine.LineStartList, aWedLine.LineEndList, WedLineList); //move all remaining linesegements to a newly created line, add the new wedline to the end of the wedline list and move on to to the next wedline
end;

procedure TForm1.SwitchSearchDirection(SearchDirection: TDirection);
var TempList: TList<integer>;
begin

  TempList := TList<integer>.create;

  try
    If SearchDirection = FromBeginning then  //remove last added child and index
    begin
      If aWedLine.children.Count >= 1 then
      begin
        aWedLine.children.delete(aWedLine.children.Count-1);
        IndexList.delete(IndexList.Count-1);
      end;
    end;

    //switch line start and line end lists
    TempList.AddRange(aWedLine.LineStartList);
    aWedLine.LineStartList.Clear;
    aWedLine.LineStartList.AddRange(aWedLine.LineEndList);
    aWedLine.LineEndList.Clear;
    aWedLine.LineEndList.AddRange(TempList);
  finally
    TempList.Free;
  end;

end;

